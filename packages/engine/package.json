{
  "name": "@anticlaude/engine",
  "version": "1.1.0",
  "description": "AntiClaude core engine: agent red-team evals, report compare, local guard, and runtime policy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "AGPL-3.0-only",
  "author": "AntiClaude",
  "repository": {
    "type": "git",
    "url": "https://github.com/TacticSpaceTech/AntiClaude",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/TacticSpaceTech/AntiClaude",
  "bugs": {
    "url": "https://github.com/TacticSpaceTech/AntiClaude/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc && cp src/payloads.json dist/payloads.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "security",
    "red-team",
    "prompt-injection",
    "owasp",
    "eval",
    "llm-security",
    "mcp"
  ]
}
